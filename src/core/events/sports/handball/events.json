    {
      "id": "goal_margin",
      "position": 5,
      "priority": "medium",
      "labelTemplate": {
        "fr": "Ecart {{direction}} de {{value}} buts",
        "en": "Margin {{direction}} {{value}} goals"
      },
      "expressionTemplate": "(score.home > score.away ? score.home - score.away : score.away - score.home) {{operator}} {{value}}",
      "category": "margin",
      "description": {
        "fr": "Prediction sur l'ecart de buts entre les deux equipes",
        "en": "Prediction on the goal margin between the two teams"
      },
      "paramFields": [
        {
          "name": "value",
          "type": "number",
          "label": {
            "fr": "Ecart de buts",
            "en": "Goal margin"
          },
          "min": 0.5,
          "max": 15,
          "step": 0.5,
          "default": 3.5
        },
        {
          "name": "direction",
          "type": "enum",
          "label": {
            "fr": "Plus ou moins",
            "en": "Over or under"
          },
          "options": [
