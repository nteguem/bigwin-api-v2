        "en": "{{direction}} {{value}} goals in 1st half"
      },
      "expressionTemplate": "firstHalfTotal {{operator}} {{value}}",
      "category": "halftime",
      "description": {
        "fr": "Prediction sur le nombre total de buts en premiere mi-temps",
        "en": "Prediction on the total number of goals in first half"
      },
      "paramFields": [
        {
          "name": "value",
          "type": "number",
          "label": {
            "fr": "Nombre de buts",
