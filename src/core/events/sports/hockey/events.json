{
  "staticEvents": [
    {
      "id": "home_win",
      "position": 1,
      "priority": "high",
      "label": {
        "fr": "Victoire equipe domicile",
        "en": "Home team wins"
      },
      "expression": "score.home > score.away",
      "category": "result",
      "description": {
        "fr": "L'equipe qui joue a domicile gagne le match",
        "en": "The home team wins the match"
      }
    },
    {
      "id": "away_win",
      "position": 2,
      "priority": "high",
      "label": {
        "fr": "Victoire equipe exterieur",
        "en": "Away team wins"
      },
      "expression": "score.away > score.home",
      "category": "result",
      "description": {
        "fr": "L'equipe qui joue a l'exterieur gagne le match",
        "en": "The away team wins the match"
      }
    },
    {
      "id": "draw_regulation",
      "position": 3,
      "priority": "medium",
      "label": {
        "fr": "Egalite en temps reglementaire",
        "en": "Tied in regulation"
      },
      "expression": "regulationGoalsHome === regulationGoalsAway",
      "category": "result",
      "description": {
        "fr": "Les equipes sont a egalite a la fin du temps reglementaire",
        "en": "Teams are tied at the end of regulation time"
      }
    },
    {
      "id": "both_teams_score",
      "position": 4,
      "priority": "high",
      "label": {
        "fr": "Les deux equipes marquent",
        "en": "Both teams score"
      },
      "expression": "bothTeamsScore === true",
      "category": "goals",
      "description": {
        "fr": "Chaque equipe marque au moins un but",
        "en": "Each team scores at least one goal"
      }
    },
    {
      "id": "both_teams_score_no",
      "position": 5,
      "priority": "medium",
      "label": {
        "fr": "Une equipe ne marque pas",
        "en": "One team doesn't score"
      },
      "expression": "bothTeamsScore === false",
      "category": "goals",
      "description": {
        "fr": "Au moins une des deux equipes ne marque aucun but",
        "en": "At least one of the teams doesn't score any goal"
      }
    },
    {
      "id": "home_clean_sheet",
      "position": 6,
      "priority": "medium",
      "label": {
        "fr": "Domicile sans encaisser",
        "en": "Home clean sheet"
      },
      "expression": "score.away === 0",
      "category": "goals",
      "description": {
        "fr": "L'equipe domicile ne concede aucun but",
        "en": "Home team doesn't concede any goal"
      }
    },
    {
      "id": "away_clean_sheet",
      "position": 7,
      "priority": "medium",
      "label": {
        "fr": "Exterieur sans encaisser",
        "en": "Away clean sheet"
      },
      "expression": "score.home === 0",
      "category": "goals",
      "description": {
        "fr": "L'equipe exterieur ne concede aucun but",
        "en": "Away team doesn't concede any goal"
      }
    },
    {
      "id": "has_overtime",
      "position": 8,
      "priority": "medium",
      "label": {
        "fr": "Prolongations jouees",
        "en": "Overtime played"
      },
      "expression": "hasOvertime === true",
      "category": "special",
      "description": {
        "fr": "Le match va en prolongation",
        "en": "The match goes to overtime"
      }
    },
    {
      "id": "has_penalties",
      "position": 9,
      "priority": "medium",
      "label": {
        "fr": "Seance de tirs au but",
        "en": "Shootout played"
      },
      "expression": "hasPenalties === true",
      "category": "special",
      "description": {
        "fr": "Le match se decide aux tirs au but",
        "en": "The match is decided by a shootout"
      }
    },
    {
      "id": "decided_in_regulation",
      "position": 10,
      "priority": "medium",
      "label": {
        "fr": "Match decide en temps reglementaire",
        "en": "Match decided in regulation"
      },
      "expression": "hasOvertime === false && hasPenalties === false",
      "category": "special",
      "description": {
        "fr": "Le match se termine dans le temps reglementaire sans prolongation",
        "en": "The match ends in regulation time without overtime"
      }
    }
  ],
  "parametricEvents": [
    {
      "id": "total_goals",
      "position": 1,
      "priority": "high",
      "labelTemplate": {
        "fr": "{{direction}} de {{value}} buts au total",
        "en": "{{direction}} {{value}} total goals"
      },
      "expressionTemplate": "totalGoals {{operator}} {{value}}",
      "category": "goals",
      "description": {
        "fr": "Prediction sur le nombre total de buts dans le match",
        "en": "Prediction on the total number of goals in the match"
      },
      "paramFields": [
        {
          "name": "value",
          "type": "number",
          "label": {
            "fr": "Nombre de buts",
            "en": "Number of goals"
          },
          "min": 1,
          "max": 15,
          "step": 0.5,
          "default": 5.5
        },
        {
          "name": "direction",
          "type": "enum",
          "label": {
            "fr": "Plus ou moins",
            "en": "Over or under"
          },
          "options": [
            {
              "value": "over",
              "label": {
                "fr": "Plus",
                "en": "Over"
              }
            },
            {
              "value": "under",
              "label": {
                "fr": "Moins",
                "en": "Under"
              }
            }
          ],
          "default": "over"
        }
      ]
    },
    {
      "id": "home_goals",
      "position": 2,
      "priority": "medium",
      "labelTemplate": {
        "fr": "Equipe domicile {{direction}} de {{value}} buts",
        "en": "Home team {{direction}} {{value}} goals"
      },
      "expressionTemplate": "score.home {{operator}} {{value}}",
      "category": "team_goals",
      "description": {
        "fr": "Prediction sur le nombre de buts de l'equipe domicile",
        "en": "Prediction on the number of goals by home team"
      },
      "paramFields": [
        {
          "name": "value",
          "type": "number",
          "label": {
            "fr": "Nombre de buts",
            "en": "Number of goals"
          },
          "min": 0,
          "max": 10,
          "step": 0.5,
          "default": 2.5
        },
        {
          "name": "direction",
          "type": "enum",
          "label": {
            "fr": "Plus ou moins",
            "en": "Over or under"
          },
          "options": [
            {
              "value": "over",
              "label": {
                "fr": "Plus",
                "en": "Over"
              }
            },
            {
              "value": "under",
              "label": {
                "fr": "Moins",
                "en": "Under"
              }
            }
          ],
          "default": "over"
        }
      ]
    },
    {
      "id": "away_goals",
      "position": 3,
      "priority": "medium",
      "labelTemplate": {
        "fr": "Equipe exterieur {{direction}} de {{value}} buts",
        "en": "Away team {{direction}} {{value}} goals"
      },
      "expressionTemplate": "score.away {{operator}} {{value}}",
      "category": "team_goals",
      "description": {
        "fr": "Prediction sur le nombre de buts de l'equipe exterieur",
        "en": "Prediction on the number of goals by away team"
      },
      "paramFields": [
        {
          "name": "value",
          "type": "number",
          "label": {
            "fr": "Nombre de buts",
            "en": "Number of goals"
          },
          "min": 0,
          "max": 10,
          "step": 0.5,
          "default": 2.5
        },
        {
          "name": "direction",
          "type": "enum",
          "label": {
            "fr": "Plus ou moins",
            "en": "Over or under"
          },
          "options": [
            {
              "value": "over",
              "label": {
                "fr": "Plus",
                "en": "Over"
              }
            },
            {
              "value": "under",
              "label": {
                "fr": "Moins",
                "en": "Under"
              }
            }
          ],
          "default": "over"
        }
      ]
    },
    {
      "id": "goal_margin",
      "position": 4,
      "priority": "medium",
      "labelTemplate": {
        "fr": "Ecart {{direction}} de {{value}} buts",
        "en": "Margin {{direction}} {{value}} goals"
      },
      "expressionTemplate": "(score.home > score.away ? score.home - score.away : score.away - score.home) {{operator}} {{value}}",
      "category": "margin",
      "description": {
        "fr": "Prediction sur l'ecart de buts entre les deux equipes",
        "en": "Prediction on the goal margin between the two teams"
      },
      "paramFields": [
        {
          "name": "value",
          "type": "number",
          "label": {
            "fr": "Ecart de buts",
            "en": "Goal margin"
          },
          "min": 0.5,
          "max": 10,
          "step": 0.5,
          "default": 1.5
        },
        {
          "name": "direction",
          "type": "enum",
          "label": {
            "fr": "Plus ou moins",
            "en": "Over or under"
          },
          "options": [
            {
              "value": "over",
              "label": {
                "fr": "Plus",
                "en": "Over"
              }
            },
            {
              "value": "under",
              "label": {
                "fr": "Moins",
                "en": "Under"
              }
            }
          ],
          "default": "over"
        }
      ]
    }
  ],
  "categories": {
    "result": {
      "fr": "Resultat du match",
      "en": "Match result"
    },
    "goals": {
      "fr": "Nombre de buts",
      "en": "Number of goals"
    },
    "team_goals": {
      "fr": "Buts par equipe",
      "en": "Goals by team"
    },
    "margin": {
      "fr": "Ecart de buts",
      "en": "Goal margin"
    },
    "special": {
      "fr": "Evenements speciaux",
      "en": "Special events"
    }
  }
}
