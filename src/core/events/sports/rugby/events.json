    {
      "id": "point_margin",
      "position": 5,
      "priority": "medium",
      "labelTemplate": {
        "fr": "Ecart {{direction}} de {{value}} points",
        "en": "Margin {{direction}} {{value}} points"
      },
      "expressionTemplate": "(score.home > score.away ? score.home - score.away : score.away - score.home) {{operator}} {{value}}",
      "category": "margin",
      "description": {
        "fr": "Prediction sur l'ecart de points entre les deux equipes",
        "en": "Prediction on the point margin between the two teams"
      },
      "paramFields": [
        {
          "name": "value",
          "type": "number",
          "label": {
            "fr": "Ecart de points",
            "en": "Point margin"
          },
          "min": 0.5,
          "max": 30,
          "step": 0.5,
          "default": 6.5
        },
        {
          "name": "direction",
          "type": "enum",
          "label": {
            "fr": "Plus ou moins",
            "en": "Over or under"
          },
