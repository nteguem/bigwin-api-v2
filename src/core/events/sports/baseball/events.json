                "en": "Under"
              }
            }
          ],
          "default": "over"
        }
      ]
    },
    {
      "id": "total_hits",
      "position": 4,
      "priority": "medium",
      "labelTemplate": {
        "fr": "{{direction}} de {{value}} hits au total",
        "en": "{{direction}} {{value}} total hits"
      },
      "expressionTemplate": "totalHits {{operator}} {{value}}",
      "category": "hits",
      "description": {
        "fr": "Prediction sur le nombre total de hits dans le match",
        "en": "Prediction on the total number of hits in the match"
      },
      "paramFields": [
        {
          "name": "value",
          "type": "number",
          "label": {
            "fr": "Nombre de hits",
            "en": "Number of hits"
          },
          "min": 5,
          "max": 30,
          "step": 0.5,
          "default": 16.5
        },
        {
          "name": "direction",
          "type": "enum",
          "label": {
            "fr": "Plus ou moins",
            "en": "Over or under"
          },
          "options": [
            {
              "value": "over",
