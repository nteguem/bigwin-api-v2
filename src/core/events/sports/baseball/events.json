      },
      "expressionTemplate": "score.away {{operator}} {{value}}",
      "category": "team_runs",
      "description": {
        "fr": "Prediction sur le nombre de runs de l'equipe exterieur",
        "en": "Prediction on the number of runs by away team"
      },
      "paramFields": [
        {
          "name": "value",
          "type": "number",
          "label": {
            "fr": "Nombre de runs",
            "en": "Number of runs"
          },
          "min": 0,
          "max": 15,
          "step": 0.5,
          "default": 4.5
        },
        {
          "name": "direction",
          "type": "enum",
          "label": {
            "fr": "Plus ou moins",
            "en": "Over or under"
          },
          "options": [
            {
              "value": "over",
              "label": {
                "fr": "Plus",
                "en": "Over"
              }
            },
            {
              "value": "under",
              "label": {
