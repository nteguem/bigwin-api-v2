    },
    {
      "id": "run_margin",
      "position": 5,
      "priority": "medium",
      "labelTemplate": {
        "fr": "Ecart {{direction}} de {{value}} runs",
        "en": "Margin {{direction}} {{value}} runs"
      },
      "expressionTemplate": "(score.home > score.away ? score.home - score.away : score.away - score.home) {{operator}} {{value}}",
      "category": "margin",
      "description": {
        "fr": "Prediction sur l'ecart de runs entre les deux equipes",
        "en": "Prediction on the run margin between the two teams"
      },
      "paramFields": [
        {
          "name": "value",
          "type": "number",
          "label": {
            "fr": "Ecart de runs",
            "en": "Run margin"
          },
          "min": 0.5,
          "max": 10,
          "step": 0.5,
          "default": 1.5
        },
        {
          "name": "direction",
          "type": "enum",
          "label": {
            "fr": "Plus ou moins",
            "en": "Over or under"
          },
          "options": [
            {
              "value": "over",
              "label": {
